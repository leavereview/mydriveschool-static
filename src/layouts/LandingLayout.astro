---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage = '/images/og-default.jpg' } = Astro.props;
const GOOGLE_ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID || '';
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <meta http-equiv="x-dns-prefetch-control" content="on" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, 'https://driveschoolpro.com')} />
  <meta property="og:site_name" content="DriveSchoolPro" />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(ogImage, 'https://driveschoolpro.com')} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />

  <slot name="head" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>

  <!--
    GA4 Configuration — driveschoolpro.com

    Measurement ID: G-2E741HXVN9 (via data stream "driveschoolpro.com", created 2026-03-20)
    Cross-domain: linked to app.driveschoolpro.com for signup attribution (setup: 2026-04-20)

    Known data-quality gaps:
    - Before 2026-01-26: cookie consent not yet added; GA4 undercounted
    - ~2026-03-20: measurement ID typo in effect for part of the day (commit f7894ec)
    - Before 2026-04-18: Google Ads conversion tracking not attached; paid CAC unattributable
    - Before 2026-04-20: cross-domain linker not configured; signup conversions unattributed

    Any historical analysis crossing these dates needs caveating.
  -->
  <script is:inline define:vars={{ GOOGLE_ADS_ID }}>
    (function() {
      try {
        const consent = localStorage.getItem('dsp-cookie-consent');
        if (consent) {
          const consentData = JSON.parse(consent);
          if (consentData.consent === 'all') {
            const script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=G-2E741HXVN9';
            document.head.appendChild(script);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', 'G-2E741HXVN9', {
              linker: {
                domains: ['driveschoolpro.com', 'app.driveschoolpro.com'],
                accept_incoming: true
              }
            });
            if (GOOGLE_ADS_ID) { gtag('config', GOOGLE_ADS_ID); }
          }
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col pb-20 md:pb-0">
  <main class="flex-grow">
    <slot />
  </main>

  <footer class="py-6 text-center text-gray-400 text-sm border-t border-gray-100">
    <p>© 2026 DriveSchoolPro ·
      <a href="/privacy-policy/" class="hover:text-gray-600 underline">Privacy Policy</a> ·
      <a href="/terms/" class="hover:text-gray-600 underline">Terms of Service</a>
    </p>
  </footer>
</body>
</html>
