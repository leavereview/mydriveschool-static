---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  schemaType?: 'Article' | 'BlogPosting' | 'WebPage' | 'CollectionPage';
  publishedDate?: string;
  modifiedDate?: string;
  noindex?: boolean;
  author?: string;
}

const {
  title,
  description = 'DriveSchoolPro - The complete driving school management platform. Scheduling, student management, instructor allocation, and online booking.',
  image = '/images/og-default.jpg',
  type = 'website',
  schemaType,
  publishedDate,
  modifiedDate,
  noindex = false,
  author = 'John Powell'
} = Astro.props;
const GOOGLE_ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID || '';

// Determine the schema type to use
const resolvedSchemaType = schemaType || (type === 'article' ? 'Article' : 'WebPage');

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Dynamic title suffix: skip for long titles, use shorter brand name
const getTitleSuffix = (pageTitle: string): string => {
  if (pageTitle === 'Home') return 'DriveSchoolPro - Driving School Management Software';
  if (pageTitle.includes('DriveSchoolPro')) return pageTitle; // Already has brand suffix
  if (pageTitle.length > 50) return pageTitle; // No suffix for very long titles
  return `${pageTitle} | DriveSchoolPro`;
};
const fullTitle = getTitleSuffix(title);

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://driveschoolpro.com/#organization",
      "name": "DriveSchoolPro",
      "url": "https://driveschoolpro.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://driveschoolpro.com/favicon.svg"
      },
      "sameAs": [
        "https://twitter.com/mydriveschool",
        "https://www.linkedin.com/company/driveschoolpro/",
        "https://www.facebook.com/mydriveschool"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Support",
        "email": "support@driveschoolpro.com",
        "url": "https://driveschoolpro.com/contact/"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "124 City Road",
        "addressLocality": "London",
        "postalCode": "EC1V 2NX",
        "addressCountry": "GB"
      },
      "foundingDate": "2024",
      "description": "Complete driving school management software for scheduling lessons, managing instructors, tracking student progress, and online booking."
    },
    {
      "@type": "WebSite",
      "@id": "https://driveschoolpro.com/#website",
      "url": "https://driveschoolpro.com",
      "name": "DriveSchoolPro",
      "publisher": {
        "@id": "https://driveschoolpro.com/#organization"
      }
    },
    {
      "@type": resolvedSchemaType,
      "@id": canonicalURL.href,
      "url": canonicalURL.href,
      "name": title,
      "description": description,
      "isPartOf": {
        "@id": "https://driveschoolpro.com/#website"
      },
      ...(publishedDate && { "datePublished": publishedDate }),
      ...(modifiedDate && { "dateModified": modifiedDate }),
      ...((resolvedSchemaType === 'Article' || resolvedSchemaType === 'BlogPosting') && {
        "author": {
          "@type": "Person",
          "name": author,
          "url": "https://driveschoolpro.com/about/",
          "jobTitle": "Founder",
          "image": "https://driveschoolpro.com/images/about-founder.jpg",
          "sameAs": ["https://www.linkedin.com/in/johnpowellpm/"]
        },
        "publisher": {
          "@id": "https://driveschoolpro.com/#organization"
        }
      })
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="TxPeMNH_MLK0ARhPR5U4AerAG4iJv2-MYoAG4Os_w3c" />
  <meta name="generator" content={Astro.generator} />

  <!-- Performance optimizations -->
  <meta http-equiv="x-dns-prefetch-control" content="on" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

  <title>{fullTitle}</title>
  <meta name="title" content={fullTitle} />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en-GB" href={canonicalURL} />
  <meta name="geo.region" content="GB" />
  <meta name="geo.placename" content="United Kingdom" />

  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:site_name" content="DriveSchoolPro" />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={fullTitle} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.site)} />

  <!-- Mobile browser chrome colour -->
  <meta name="theme-color" content="#1A1A2E" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>

  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  <slot name="head" />

  <!--
    GA4 Configuration — driveschoolpro.com

    Measurement ID: G-2E741HXVN9 (via data stream "driveschoolpro.com", created 2026-03-20)
    Cross-domain: linked to app.driveschoolpro.com for signup attribution (setup: 2026-04-20)

    Known data-quality gaps:
    - Before 2026-01-26: cookie consent not yet added; GA4 undercounted
    - ~2026-03-20: measurement ID typo in effect for part of the day (commit f7894ec)
    - Before 2026-04-18: Google Ads conversion tracking not attached; paid CAC unattributable
    - Before 2026-04-20: cross-domain linker not configured; signup conversions unattributed

    Any historical analysis crossing these dates needs caveating.
  -->
  <!-- Google Analytics + Google Ads - Conditional Loading Based on Cookie Consent -->
  <script is:inline define:vars={{ GOOGLE_ADS_ID }}>
    (function() {
      try {
        const consent = localStorage.getItem('dsp-cookie-consent');
        if (consent) {
          const consentData = JSON.parse(consent);
          if (consentData.consent === 'all') {
            const script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=G-2E741HXVN9';
            document.head.appendChild(script);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', 'G-2E741HXVN9', {
              linker: {
                domains: ['driveschoolpro.com', 'app.driveschoolpro.com'],
                accept_incoming: true
              }
            });
            if (GOOGLE_ADS_ID) { gtag('config', GOOGLE_ADS_ID); }
          }
        }
      } catch (error) {
        console.error('Error loading analytics:', error);
      }
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-brand-red focus:text-white focus:rounded-lg focus:shadow-lg">
    Skip to main content
  </a>
  <Navigation />

  <main id="main-content" class="flex-grow pt-16 md:pt-20">
    <PromoBanner />
    <slot />
  </main>

  <Footer />
  <CookieConsent />
</body>
</html>
