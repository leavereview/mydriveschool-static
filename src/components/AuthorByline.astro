---
interface Props {
  date: string;
}
const { date } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<div class="flex items-center gap-4 mt-4">
  <a href="/about/" class="flex-shrink-0">
    <img
      src="/images/about-founder.jpg"
      alt="John Powell"
      width="48"
      height="48"
      class="rounded-full w-12 h-12 object-cover border-2 border-white/30"
      loading="eager"
    />
  </a>
  <div>
    <div class="flex items-center gap-2 text-white font-semibold">
      <a href="/about/" class="hover:underline">John Powell</a>
      <span class="text-gray-400 text-sm font-normal">·</span>
      <span class="text-gray-400 text-sm font-normal">Founder, DriveSchoolPro</span>
    </div>
    <div class="flex items-center gap-3 text-sm text-gray-300 mt-0.5">
      <time datetime={date}>{formattedDate}</time>
      <span>·</span>
      <a
        href="https://www.linkedin.com/in/johnpowellpm/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white transition-colors"
        aria-label="John Powell on LinkedIn"
      >LinkedIn</a>
    </div>
    <p class="text-xs text-gray-400 mt-1 max-w-md">
      Built and sold RevelationPets.com. First Class Honours in Software Engineering. 20+ years in SaaS.
    </p>
  </div>
</div>
