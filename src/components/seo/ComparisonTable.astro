---
/**
 * Comparison Table Component
 *
 * Creates SEO-optimized comparison tables that:
 * - Use semantic HTML table markup
 * - Include proper headers and scope attributes
 * - Are mobile responsive
 * - Support sorting (optional)
 * - Generate table structured data
 *
 * Usage:
 * <ComparisonTable
 *   title="Why Schools Choose DriveSchoolPro"
 *   headers={['DriveSchoolPro', 'Generic Software', 'Manual/Spreadsheets']}
 *   rows={tableData}
 * />
 */

interface ComparisonRow {
  label: string;
  values: (string | number | boolean)[];
  highlight?: boolean;
}

interface Props {
  title: string;
  description?: string;
  headers: string[];
  rows: ComparisonRow[];
  rowHeader?: string;       // Header label for the feature-name column (default: empty)
  highlightColumn?: number; // 0-based index into headers[] to highlight (default: 0)
  sortable?: boolean;
  className?: string;
}

const {
  title,
  description,
  headers,
  rows,
  rowHeader = '',
  highlightColumn = 0,
  sortable = false,
  className = ''
} = Astro.props;

function formatValue(value: string | number | boolean): { text: string; type: 'true' | 'false' | 'text' } {
  if (value === true)  return { text: 'Yes', type: 'true' };
  if (value === false) return { text: 'No',  type: 'false' };
  return { text: String(value), type: 'text' };
}
---

<section class={`py-12 md:py-16 bg-gray-50 ${className}`}>
  <div class="container-custom">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-navy mb-2">{title}</h2>
      {description && (
        <p class="text-gray-600 mb-6 text-base">{description}</p>
      )}

      <div class="overflow-x-auto -mx-4 px-4 md:mx-0 md:px-0">
        <div class="rounded-xl overflow-hidden shadow-sm">
        <table class="w-full border-collapse bg-white text-sm md:text-base" role="table" style="min-width: 560px;">
          <thead>
            <tr>
              <!-- Feature name column header -->
              <th scope="col" class="text-left py-3 px-4 font-semibold text-gray-700 border-b-2 border-gray-200 bg-gray-100 w-[40%]">
                {rowHeader}
              </th>
              <!-- Value column headers -->
              {headers.map((header, i) => (
                <th
                  scope="col"
                  class={[
                    'text-center py-3 px-4 font-bold border-b-2 w-[20%]',
                    i === highlightColumn
                      ? 'bg-[#FFF0F3] text-brand-red border-brand-red/30'
                      : 'bg-gray-100 text-gray-700 border-gray-200'
                  ].join(' ')}
                  data-column={i + 1}
                >
                  {header}
                  {sortable && <span class="sort-icon ml-1 opacity-60 text-xs" aria-hidden="true">↕</span>}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr class={['border-b border-gray-100 transition-colors', row.highlight ? 'bg-amber-50/60 hover:bg-amber-50' : 'hover:bg-gray-50'].join(' ')}>
                <!-- Feature name cell -->
                <th scope="row" class="text-left py-3 px-4 font-medium text-gray-800 text-sm md:text-base">
                  {row.label}
                </th>
                <!-- Value cells -->
                {row.values.map((value, i) => {
                  const { text, type } = formatValue(value);
                  const isDsp = i === highlightColumn;
                  return (
                    <td class={[
                      'py-3 px-4 text-center',
                      isDsp ? 'bg-[#FFFBFC]' : ''
                    ].join(' ')}>
                      {type === 'true' && (
                        <span class="inline-flex items-center justify-center" aria-label="Yes">
                          <svg class={['w-5 h-5 mx-auto', isDsp ? 'text-brand-red' : 'text-green-500'].join(' ')} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                          </svg>
                        </span>
                      )}
                      {type === 'false' && (
                        <span class="inline-flex items-center justify-center" aria-label="No">
                          <svg class="w-5 h-5 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                          </svg>
                        </span>
                      )}
                      {type === 'text' && (
                        <span class="text-gray-700">{text}</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      </div>
    </div>
  </div>
</section>

{sortable && (
  <script>
    document.querySelectorAll('.comparison-table th.sortable').forEach(header => {
      header.addEventListener('click', () => {
        const table = header.closest('table');
        const tbody = table?.querySelector('tbody');
        const columnIndex = parseInt(header.getAttribute('data-column') || '0');
        if (!tbody) return;
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const isAscending = header.classList.contains('sort-asc');
        rows.sort((a, b) => {
          const aValue = a.children[columnIndex].textContent?.trim() || '';
          const bValue = b.children[columnIndex].textContent?.trim() || '';
          const aNum = parseFloat(aValue);
          const bNum = parseFloat(bValue);
          if (!isNaN(aNum) && !isNaN(bNum)) return isAscending ? bNum - aNum : aNum - bNum;
          return isAscending ? bValue.localeCompare(aValue) : aValue.localeCompare(bValue);
        });
        rows.forEach(row => tbody.appendChild(row));
        if (table) table.querySelectorAll('th').forEach(th => th.classList.remove('sort-asc', 'sort-desc'));
        header.classList.add(isAscending ? 'sort-desc' : 'sort-asc');
      });
    });
  </script>
)}
