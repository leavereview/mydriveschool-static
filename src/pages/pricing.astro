---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { OFFER, PROMO } from '../config/offer';

// Pricing tiers (monthly, GBP)
const pricingTiers = [
  { name: 'Solo Plan', description: 'For independent ADIs', monthlyPrice: 22, popular: false, comingSoon: false },
  { name: 'School Plan', description: 'For driving schools', monthlyPrice: 22, popular: true, comingSoon: false } // per-instructor: £22 first + £12 each additional, up to 5 instructors
];
// Note: Enterprise plan removed from display — only Solo and School shown.

// Offer schemas — only generate for plans that are available now
const offerSchemas = pricingTiers.filter(t => !t.comingSoon).map((tier) => ({
  "@context": "https://schema.org",
  "@type": "Offer",
  "@id": `https://driveschoolpro.com/pricing/#${tier.name.toLowerCase().replace(/\s+/g, '-')}`,
  "name": tier.name,
  "description": `${tier.description}. No setup fees, no contracts, cancel anytime.`,
  "price": tier.monthlyPrice,
  "priceCurrency": "GBP",
  "priceSpecification": {
    "@type": "UnitPriceSpecification",
    "price": tier.monthlyPrice,
    "priceCurrency": "GBP",
    "unitText": "month",
    "billingIncrement": 1
  },
  "priceValidUntil": "2026-12-31",
  "availability": "https://schema.org/InStock",
  "url": OFFER.ctaPrimary.href,
  "seller": {
    "@type": "Organization",
    "name": "DriveSchoolPro"
  },
  "itemOffered": {
    "@id": "https://driveschoolpro.com/#software"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Free Trial",
      "value": OFFER.short
    },
    {
      "@type": "PropertyValue",
      "name": "Setup Fee",
      "value": "No"
    }
  ]
}));

// FAQ schema for pricing page
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://driveschoolpro.com/pricing/#faqpage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is there a free trial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes — every plan starts with ${OFFER.short}, with no credit card required.`
      }
    },
    {
      "@type": "Question",
      "name": "How much does driving school software cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DriveSchoolPro's Solo Plan is £22/month for independent ADIs with unlimited students, DVSA progress tracking, scheduling, and invoicing. The multi-instructor School Plan is £22/month for your first instructor, then £12/month for each additional, up to 5 instructors (so a 5-instructor school is £70/month — £14 per instructor). There are no setup fees and no long-term contracts."
      }
    },
    {
      "@type": "Question",
      "name": "Can I change plans later?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can upgrade from Solo to School (or back) at any time. Changes take effect on your next billing cycle."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No long-term contracts. All plans are month-to-month and you can cancel anytime with no cancellation fees."
      }
    },
    {
      "@type": "Question",
      "name": "What payment methods do you accept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For your subscription, we accept all major credit and debit cards, billed securely by Stripe. For student payments within the software, you can record cash, bank transfer, and cheque — online card payments for students are coming soon."
      }
    },
    {
      "@type": "Question",
      "name": "How is my data kept secure, and where is it hosted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DriveSchoolPro is run by LEAVE.REVIEW LTD, a UK company and the data controller under UK GDPR. Payments are handled by Stripe (PCI DSS Level 1) and your data is encrypted at rest. Our sub-processors are Stripe, Neon, Vercel and Resend."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data used to train AI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Lesson briefings are generated by Claude (Anthropic). Your data is sent securely to produce each briefing and is not used to train any AI model."
      }
    },
    {
      "@type": "Question",
      "name": "I'm switching from paper, WhatsApp or a spreadsheet — is it hard?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Most instructors are set up in about 10 minutes, and you can keep your current diary running alongside until you're confident. The 14-day free trial needs no card."
      }
    },
    {
      "@type": "Question",
      "name": "Which reminders can I send — email or WhatsApp?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Reminders go out by email with one-click confirm, so pupils can confirm or reschedule before the lesson. WhatsApp is coming soon."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer refunds?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You start with a 14-day free trial (no card), so you can decide before you pay anything. Plans are monthly — cancel anytime before your renewal date and you won't be charged again."
      }
    }
  ]
};

// Free trial schema
const freeTrialSchema = {
  "@context": "https://schema.org",
  "@type": "Offer",
  "@id": "https://driveschoolpro.com/pricing/#free-trial",
  "name": `14-Day Free Trial - DriveSchoolPro`,
  "description": `${OFFER.long}. No credit card required.`,
  "price": "0",
  "priceCurrency": "GBP",
  "priceValidUntil": "2026-12-31",
  "availability": "https://schema.org/InStock",
  "url": OFFER.ctaPrimary.href,
  "eligibleRegion": {
    "@type": "Place",
    "name": "United Kingdom"
  },
  "itemOffered": {
    "@id": "https://driveschoolpro.com/#software"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Trial Duration",
      "value": OFFER.short
    },
    {
      "@type": "PropertyValue",
      "name": "Credit Card Required",
      "value": "No"
    }
  ]
};
---

<BaseLayout title="Driving School Software Pricing 2026: From £22/month" description={`Driving school software from £22/month. DVSA tracking, scheduling, automated reminders, and invoicing included. No hidden fees. ${OFFER.meta}`} image="/images/hero-pricing.jpg">
  <Fragment slot="head">
    {offerSchemas.map(offerSchema => (
      <script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(freeTrialSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumbs -->
  <div class="bg-gray-100 py-3">
    <div class="container-custom">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Pricing' }
      ]} />
    </div>
  </div>

  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-pricing.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl text-center mx-auto">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Pricing</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Driving School Software Pricing</h1>
        <p class="text-xl text-gray-300">No setup fees. No contracts. Cancel anytime. Just powerful driving school software.</p>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-brand-navy mb-4">Choose the Right Plan for Your Driving School</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            The Solo Plan gives independent ADIs everything they need to manage students, lessons, and DVSA progress. The School Plan adds multi-instructor tools for growing driving schools.
          </p>
          {PROMO.enabled && (
            <p class="inline-block bg-brand-red-light text-brand-navy text-sm font-medium px-4 py-2 rounded-lg">
              {PROMO.pricingNote}
            </p>
          )}
        </div>
        <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
          <!-- Solo Plan — primary action -->
          <div class="card border-2 border-brand-red ring-2 ring-brand-red/20 relative">
            <span class="badge-primary mb-2">Start Here</span>
            <h3 class="text-xl font-bold text-brand-navy mb-2">Solo</h3>
            <p class="text-gray-600 mb-4">For independent ADIs</p>
            <div class="text-4xl font-bold text-brand-navy mb-4">£22<span class="text-lg font-normal text-gray-500">/month</span></div>
            <ul class="text-left space-y-2 mb-6 text-sm">
              <li>✓ AI lesson briefings (powered by Claude)</li>
              <li>✓ Unlimited students</li>
              <li>✓ Lesson scheduling with conflict detection</li>
              <li>✓ Full DVSA 8-category framework</li>
              <li>✓ Automated Google review requests</li>
              <li>✓ Email reminders (WhatsApp coming soon)</li>
              <li>✓ Invoicing & payment recording</li>
              <li>✓ Student self-service portal</li>
            </ul>
            <a href={OFFER.ctaPrimary.href} class="btn-primary w-full">{OFFER.ctaPrimary.label}</a>
            <p class="text-center text-gray-500 text-xs mt-3">No credit card required · Cancel anytime</p>
          </div>
          <!-- School Plan -->
          <div class="card border-2 border-brand-navy relative">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-brand-navy text-white mb-2">Most Popular</span>
            <h3 class="text-xl font-bold text-brand-navy mb-2">School</h3>
            <p class="text-gray-600 mb-4">For driving schools</p>
            <div class="mb-4">
              <div class="text-4xl font-bold text-brand-navy">£22<span class="text-lg font-normal text-gray-500">/mo</span></div>
              <div class="text-sm text-gray-600 mt-1">first instructor + £12/mo each additional (up to 5)</div>
              <div class="text-xs text-gray-500 mt-1">e.g. a 5-instructor school = £70/month (£14/instructor)</div>
            </div>
            <ul class="text-left space-y-2 mb-6 text-sm">
              <li>✓ Everything in Solo</li>
              <li>✓ Up to 5 instructors (6+ → Enterprise)</li>
              <li>✓ Vehicle fleet & compliance tracking</li>
              <li>✓ Business analytics & reports</li>
              <li>✓ Role-based access control</li>
            </ul>
            <a href={OFFER.ctaPrimary.href} class="btn-primary w-full">{OFFER.ctaPrimary.label}</a>
            <p class="text-center text-gray-500 text-xs mt-3">No credit card required · Cancel anytime</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enterprise / contact sales -->
  <section class="bg-white pb-16">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto bg-brand-navy text-white rounded-2xl p-8 md:p-10 text-center">
        <h2 class="text-2xl font-bold mb-3">Running 6 or more instructors?</h2>
        <p class="text-gray-300 mb-6 max-w-xl mx-auto">Enterprise adds unlimited instructors, priority support, and custom onboarding tailored to larger schools. Tell us about your school and we'll put together a custom quote.</p>
        <a href="/contact/" class="btn-primary">Contact sales</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-8 text-center">What's Included in Every Plan</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Drag-and-Drop Calendar</h3>
            <p class="text-gray-600 text-sm">Interactive calendar with day, week, and month heatmap views. Reschedule lessons with drag-and-drop. Create recurring lesson series for regular students.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Automated Reminders</h3>
            <p class="text-gray-600 text-sm">Email reminders with configurable timing. WhatsApp coming soon. Per-student notification preferences and full delivery logs so you know every message was received.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">DVSA Progress Tracking</h3>
            <p class="text-gray-600 text-sm">Full DVSA competency framework with 27 skills across 8 DVSA categories. Track each student's journey from Not Started to Reflection on a 6-level scale.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Student Portal</h3>
            <p class="text-gray-600 text-sm">Students log in to view upcoming lessons, track their DVSA progress, check package balances, and update their personal details.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Online Booking Widget</h3>
            <p class="text-gray-600 text-sm">Embed a booking widget on your website so students can book lessons 24/7. You control available slots, lesson types, and booking rules.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Test & Document Tracking</h3>
            <p class="text-gray-600 text-sm">Record driving test bookings and results. Upload student documents with expiry alerts. Monitor your school's first-time pass rate.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost breakdown section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">How Much Does Driving School Software Cost?</h2>
        <p class="text-gray-600 mb-6">
          Driving school software pricing in the UK typically ranges from free (limited tools) to £100+/month for enterprise platforms. Here's how to think about the real cost:
        </p>
        <div class="overflow-x-auto mb-8">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-brand-navy text-white">
                <th class="text-left p-3 rounded-tl-lg">Plan</th>
                <th class="text-left p-3">Best for</th>
                <th class="text-left p-3">Monthly cost</th>
                <th class="text-left p-3 rounded-tr-lg">Cost per student (50 students)</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="p-3 font-medium">Solo</td>
                <td class="p-3 text-gray-600">Independent ADIs</td>
                <td class="p-3 font-bold text-brand-navy">£22/month</td>
                <td class="p-3 text-gray-600">£0.44/student</td>
              </tr>
              <tr>
                <td class="p-3 font-medium">School</td>
                <td class="p-3 text-gray-600">Multi-instructor schools</td>
                <td class="p-3 font-bold text-brand-navy">From £22/month <span class="text-xs font-normal text-gray-500">(£22 + £12/instructor)</span></td>
                <td class="p-3 text-gray-600">£70/month for 5 instructors (£14/instructor)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 mb-4">
          At £22/month, the Solo Plan pays for itself if it saves you even an hour of admin a month — and early users report saving 10+ hours weekly. The School Plan is £22/month for your first instructor and £12/month for each additional (up to 5) — £70/month for a 5-instructor school, or £14 per instructor.
        </p>
        <p class="text-gray-600">
          There are no setup fees, no per-lesson charges, and no hidden costs. You pay monthly and can cancel at any time. See <a href="/driving-school-software/" class="text-brand-red hover:underline">all driving school software features</a> included in every plan.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Is there a free trial?</h3>
            <p class="text-gray-600 text-sm">Yes — every plan starts with {OFFER.short}, with no credit card required.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Can I change plans later?</h3>
            <p class="text-gray-600 text-sm">Yes, you can upgrade from Solo to School (or back) at any time. Changes take effect on your next billing cycle.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Is there a contract?</h3>
            <p class="text-gray-600 text-sm">No long-term contracts. All plans are month-to-month and you can cancel anytime with no cancellation fees.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">What payment methods do you accept?</h3>
            <p class="text-gray-600 text-sm">For your subscription, we accept all major credit and debit cards, billed securely by Stripe. For your students, the software supports recording payments via cash, bank transfer, and cheque — online card payments for students are coming soon.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">How is my data kept secure, and where is it hosted?</h3>
            <p class="text-gray-600 text-sm">DriveSchoolPro is run by LEAVE.REVIEW LTD, a UK company and the data controller under UK GDPR. Payments are handled by Stripe (PCI DSS Level 1) and your data is encrypted at rest. Our sub-processors are Stripe, Neon, Vercel and Resend. See our <a href="/privacy-policy/" class="text-brand-red hover:underline">privacy policy</a> for detail.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Is my data used to train AI?</h3>
            <p class="text-gray-600 text-sm">No. Lesson briefings are generated by Claude (Anthropic). Your data is sent securely to produce each briefing and is not used to train any AI model.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">I'm switching from paper, WhatsApp or a spreadsheet — is it hard?</h3>
            <p class="text-gray-600 text-sm">No. Most instructors are set up in about 10 minutes, and you can keep your current diary running alongside until you're confident. The 14-day free trial needs no card.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Which reminders can I send — email or WhatsApp?</h3>
            <p class="text-gray-600 text-sm">Reminders go out by email with one-click confirm, so pupils can confirm or reschedule before the lesson. WhatsApp is coming soon.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Do you offer refunds?</h3>
            <p class="text-gray-600 text-sm">You start with a 14-day free trial (no card), so you can decide before you pay anything. Plans are monthly — cancel anytime before your renewal date and you won't be charged again.</p>
          </div>
        </div>
        <p class="text-sm text-gray-500 mt-6 text-center">
          Not sure if software is worth it? See <a href="/blog/switch-paper-diary-to-driving-school-software/#the-numbers" class="text-brand-red hover:underline">how quickly it pays for itself</a> in our switching guide.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
