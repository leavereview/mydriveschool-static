---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

// Pricing tiers
const pricingTiers = [
  { name: 'Solo Plan', description: 'For independent ADIs', monthlyPrice: 29, popular: false, comingSoon: false },
  { name: 'School Plan', description: 'For driving schools', monthlyPrice: 79, popular: false, comingSoon: true }
];

// Offer schemas — only generate for plans that are available now
const offerSchemas = pricingTiers.filter(t => !t.comingSoon).map((tier) => ({
  "@context": "https://schema.org",
  "@type": "Offer",
  "@id": `https://driveschoolpro.com/pricing/#${tier.name.toLowerCase().replace(/\s+/g, '-')}`,
  "name": tier.name,
  "description": `${tier.description}. All features included.`,
  "price": tier.monthlyPrice,
  "priceCurrency": "GBP",
  "priceSpecification": {
    "@type": "UnitPriceSpecification",
    "price": tier.monthlyPrice,
    "priceCurrency": "GBP",
    "unitText": "month",
    "billingIncrement": 1
  },
  "priceValidUntil": "2026-12-31",
  "availability": "https://schema.org/InStock",
  "url": "https://driveschoolpro.com/contact/",
  "seller": {
    "@type": "Organization",
    "name": "DriveSchoolPro"
  },
  "itemOffered": {
    "@type": "SoftwareApplication",
    "name": "DriveSchoolPro",
    "applicationCategory": "BusinessApplication"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Free Trial",
      "value": "14 days"
    },
    {
      "@type": "PropertyValue",
      "name": "Setup Fee",
      "value": "No"
    }
  ]
}));

// FAQ schema for pricing page
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://driveschoolpro.com/pricing/#faqpage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is there a free trial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all plans include a 14-day free trial with full access to all features. No credit card required to start."
      }
    },
    {
      "@type": "Question",
      "name": "How much does driving school software cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DriveSchoolPro's Solo Plan is £29/month for independent ADIs with unlimited students, DVSA progress tracking, scheduling, and invoicing. A School Plan for multi-instructor driving schools (£79/month) and Enterprise pricing for large operations are coming soon. There are no setup fees and no long-term contracts."
      }
    },
    {
      "@type": "Question",
      "name": "Can I change plans later?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When the School and Enterprise plans launch, you'll be able to upgrade seamlessly. Changes will take effect on your next billing cycle."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No long-term contracts. All plans are month-to-month and you can cancel anytime with no cancellation fees."
      }
    },
    {
      "@type": "Question",
      "name": "What payment methods do you accept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For your subscription, we accept all major credit and debit cards. For student payments within the software, you can record cash, bank transfer, and cheque. Online card payments via Stripe are coming soon."
      }
    }
  ]
};

// Free trial schema
const freeTrialSchema = {
  "@context": "https://schema.org",
  "@type": "Offer",
  "@id": "https://driveschoolpro.com/pricing/#free-trial",
  "name": "14-Day Free Trial",
  "description": "Try DriveSchoolPro free for 14 days. No credit card required.",
  "price": "0",
  "priceCurrency": "GBP",
  "priceValidUntil": "2026-12-31",
  "availability": "https://schema.org/InStock",
  "url": "https://driveschoolpro.com/contact/",
  "eligibleRegion": {
    "@type": "Place",
    "name": "United Kingdom"
  },
  "itemOffered": {
    "@type": "SoftwareApplication",
    "name": "DriveSchoolPro",
    "applicationCategory": "BusinessApplication"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Trial Duration",
      "value": "14 days"
    },
    {
      "@type": "PropertyValue",
      "name": "Credit Card Required",
      "value": "No"
    }
  ]
};
---

<BaseLayout title="Driving School Software Pricing | Plans from £29/month | DriveSchoolPro" description="Driving school software from £29/month for solo ADIs. DVSA tracking, scheduling, automated reminders, and invoicing included. No hidden fees. 14-day free trial. Multi-instructor School Plan coming soon.">
  <!-- Offer Schemas -->
  {offerSchemas.map(offerSchema => (
    <script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />
  ))}
  <script type="application/ld+json" set:html={JSON.stringify(freeTrialSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Breadcrumbs -->
  <div class="bg-gray-100 py-3">
    <div class="container-custom">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Pricing' }
      ]} />
    </div>
  </div>

  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-pricing.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl text-center mx-auto">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Pricing</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Driving School Software Pricing</h1>
        <p class="text-xl text-gray-300">All features included. No setup fees. No contracts. Just powerful driving school software.</p>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-brand-navy mb-4">Choose the Right Plan for Your Driving School</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Start with the Solo Plan — everything you need to manage your students, lessons, and DVSA progress. Multi-instructor School and Enterprise plans are coming soon.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="card border-2 border-brand-red">
            <span class="badge-primary mb-2">Available Now</span>
            <h3 class="text-xl font-bold text-brand-navy mb-2">Solo</h3>
            <p class="text-gray-600 mb-4">For independent ADIs</p>
            <div class="text-4xl font-bold text-brand-navy mb-4">£29<span class="text-lg font-normal text-gray-500">/month</span></div>
            <ul class="text-left space-y-2 mb-6 text-sm">
              <li>✓ Unlimited students</li>
              <li>✓ Lesson scheduling with conflict detection</li>
              <li>✓ DVSA progress tracking</li>
              <li>✓ Email reminders (SMS coming soon)</li>
              <li>✓ Invoicing & payment recording</li>
            </ul>
            <a href="/early-access/" class="btn-primary w-full">Become a Founding Member</a>
          </div>
          <div class="card border-2 border-gray-200 opacity-75">
            <span class="badge-coming-soon mb-2">Coming Soon</span>
            <h3 class="text-xl font-bold text-brand-navy mb-2">School</h3>
            <p class="text-gray-600 mb-4">For driving schools</p>
            <div class="text-4xl font-bold text-brand-navy mb-4">£79<span class="text-lg font-normal text-gray-500">/month</span></div>
            <ul class="text-left space-y-2 mb-6 text-sm">
              <li>✓ Everything in Solo</li>
              <li>✓ Up to 5 instructors</li>
              <li>✓ Vehicle fleet & compliance tracking</li>
              <li>✓ Business analytics & reports</li>
              <li>✓ Role-based access control</li>
            </ul>
            <span class="btn-outline w-full text-center opacity-50 cursor-default">Coming Soon</span>
          </div>
          <div class="card border-2 border-gray-200 opacity-75">
            <span class="badge-coming-soon mb-2">Coming Soon</span>
            <h3 class="text-xl font-bold text-brand-navy mb-2">Enterprise</h3>
            <p class="text-gray-600 mb-4">For large operations</p>
            <div class="text-4xl font-bold text-brand-navy mb-4">Custom</div>
            <ul class="text-left space-y-2 mb-6 text-sm">
              <li>✓ Everything in School</li>
              <li>✓ Unlimited instructors</li>
              <li>✓ Dedicated support</li>
              <li>✓ Custom onboarding</li>
            </ul>
            <span class="btn-outline w-full text-center opacity-50 cursor-default">Coming Soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-8 text-center">What's Included in Every Plan</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Drag-and-Drop Calendar</h3>
            <p class="text-gray-600 text-sm">Interactive calendar with day, week, and month heatmap views. Reschedule lessons with drag-and-drop. Create recurring lesson series for regular students.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Automated Reminders</h3>
            <p class="text-gray-600 text-sm">Email reminders with configurable timing. SMS reminders coming soon. Per-student notification preferences and full delivery logs so you know every message was received.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">DVSA Progress Tracking</h3>
            <p class="text-gray-600 text-sm">Full DVSA competency framework with 8 categories and 27 skills. Track each student's journey from Not Started to Reflection on a 6-level scale.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Student Portal <span class="badge-coming-soon ml-1">Coming Soon</span></h3>
            <p class="text-gray-600 text-sm">Students log in to view upcoming lessons, track their DVSA progress, check package balances, and update their personal details.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Online Booking Widget <span class="badge-coming-soon ml-1">Coming Soon</span></h3>
            <p class="text-gray-600 text-sm">Embed a booking widget on your website so students can book lessons 24/7. You control available slots, lesson types, and booking rules.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Test & Document Tracking</h3>
            <p class="text-gray-600 text-sm">Record driving test bookings and results. Upload student documents with expiry alerts. Monitor your school's first-time pass rate.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost breakdown section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">How Much Does Driving School Software Cost?</h2>
        <p class="text-gray-600 mb-6">
          Driving school software pricing in the UK typically ranges from free (limited tools) to £100+/month for enterprise platforms. Here's how to think about the real cost:
        </p>
        <div class="overflow-x-auto mb-8">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-brand-navy text-white">
                <th class="text-left p-3 rounded-tl-lg">Plan</th>
                <th class="text-left p-3">Best for</th>
                <th class="text-left p-3">Monthly cost</th>
                <th class="text-left p-3 rounded-tr-lg">Cost per student (50 students)</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="p-3 font-medium">Solo</td>
                <td class="p-3 text-gray-600">Independent ADIs</td>
                <td class="p-3 font-bold text-brand-navy">£29/month</td>
                <td class="p-3 text-gray-600">£0.58/student</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="p-3 font-medium">School <span class="badge-coming-soon ml-1">Coming Soon</span></td>
                <td class="p-3 text-gray-600">Multi-instructor schools</td>
                <td class="p-3 font-bold text-brand-navy">£79/month</td>
                <td class="p-3 text-gray-600">£1.58/student</td>
              </tr>
              <tr>
                <td class="p-3 font-medium">Enterprise <span class="badge-coming-soon ml-1">Coming Soon</span></td>
                <td class="p-3 text-gray-600">Large operations</td>
                <td class="p-3 font-bold text-brand-navy">Custom</td>
                <td class="p-3 text-gray-600">Contact us</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 mb-4">
          At £29/month, the Solo Plan pays for itself if it saves you just 2 hours of admin per month — and most ADIs report saving 10+ hours weekly. When the School Plan launches at £79/month, it'll work out at under £16/instructor for a 5-instructor school.
        </p>
        <p class="text-gray-600">
          There are no setup fees, no per-lesson charges, and no hidden costs. You pay monthly and can cancel at any time. See <a href="/driving-school-software/" class="text-brand-red hover:underline">all driving school software features</a> included in every plan.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Is there a free trial?</h3>
            <p class="text-gray-600 text-sm">Yes, all plans include a 14-day free trial with full access to all features. No credit card required to start.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Can I change plans later?</h3>
            <p class="text-gray-600 text-sm">When the School and Enterprise plans launch, you'll be able to upgrade seamlessly. Changes will take effect on your next billing cycle.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">Is there a contract?</h3>
            <p class="text-gray-600 text-sm">No long-term contracts. All plans are month-to-month and you can cancel anytime with no cancellation fees.</p>
          </div>
          <div class="card">
            <h3 class="font-bold text-brand-navy mb-2">What payment methods do you accept?</h3>
            <p class="text-gray-600 text-sm">For your students, the software supports recording payments via cash, bank transfer, and cheque. Online card payments via Stripe are coming soon. For your subscription, we accept all major credit and debit cards.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
