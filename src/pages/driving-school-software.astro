---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbsEnhanced from '../components/seo/BreadcrumbsEnhanced.astro';
import FeaturedAnswer from '../components/seo/FeaturedAnswer.astro';
import StatisticsSection from '../components/seo/StatisticsSection.astro';
import ComparisonTable from '../components/seo/ComparisonTable.astro';
import FAQEnhanced from '../components/seo/FAQEnhanced.astro';
import MarketingScreenshot from '../components/MarketingScreenshot.astro';

// Driving School Industry Statistics
const drivingStats = [
  {
    label: 'UK Driving Instructors',
    value: '40,000+',
    change: { value: 8, direction: 'up' as const, period: 'since 2020' },
    context: 'Approved Driving Instructors (ADIs) registered with DVSA'
  },
  {
    label: 'Active Learner Drivers',
    value: '1.2M',
    context: 'Students actively taking lessons in the UK'
  },
  {
    label: 'Admin Time Saved',
    value: '12+ hrs',
    change: { value: 75, direction: 'up' as const, period: 'weekly' },
    context: 'With automated scheduling and billing'
  },
  {
    label: 'No-Show Reduction',
    value: '65%',
    context: 'With automated email reminders'
  },
  {
    label: 'Revenue Increase',
    value: '18%',
    change: { value: 18, direction: 'up' as const, period: 'year 1' },
    context: 'With automated scheduling and lesson packages'
  },
  {
    label: 'Average Pass Rate',
    value: '46%',
    context: 'UK practical test first-time pass rate (DVSA)'
  }
];

// Comparison Table Data
const comparisonData = [
  {
    label: 'Lesson Scheduling with Conflict Detection',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Automated Reminders',
    values: [true, false, false]
  },
  {
    label: 'Student Progress Tracking',
    values: [true, false, false]
  },
  {
    label: 'DVSA Competency Framework (27 Skills)',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Invoicing & Payment Recording',
    values: [true, false, false]
  },
  {
    label: 'Vehicle Compliance Tracking (MOT/Tax/Insurance)',
    values: [true, false, false]
  },
  {
    label: 'Instructor Allocation',
    values: [true, false, false]
  },
  {
    label: 'Student Self-Service Portal',
    values: [true, false, false]
  },
  {
    label: 'Business Analytics',
    values: [true, false, false]
  },
  {
    label: 'Multi-Instructor Management',
    values: [true, false, false]
  }
];

// FAQ Items
const faqItems = [
  {
    question: "What is driving school software?",
    answer: "Driving school software is a management platform for ADIs and driving schools that handles lesson scheduling, student progress tracking, test date management, invoicing, and instructor allocation. It replaces spreadsheets, paper diaries, and WhatsApp coordination with a centralised system accessible from any device.",
    links: [
      { text: 'See pricing plans', url: '/pricing/' }
    ]
  },
  {
    question: "How much does driving school software cost?",
    answer: "DriveSchoolPro plans start from £29/month for solo ADIs with unlimited students, DVSA progress tracking, and automated reminders. Multi-instructor schools pay £79/month for up to 5 instructors with vehicle compliance tracking and business analytics. All plans include a 14-day free trial with no credit card required.",
    links: [
      { text: 'Full pricing details', url: '/pricing/' },
      { text: 'Join early access', url: '/early-access/' }
    ]
  },
  {
    question: "Can students book lessons online?",
    answer: "Students have their own secure portal where they can view upcoming and past lessons, track their DVSA competency progress, check package balances, and manage their personal details. Schools can also embed a public booking widget on their own website for new student enquiries. The student portal significantly reduces phone calls and WhatsApp messages.",
    links: [
      { text: 'Student portal features', url: '/driving-school-management-software/' }
    ]
  },
  {
    question: "Does it integrate with DVSA?",
    answer: "DriveSchoolPro includes a built-in <a href='/dvsa-27-driving-skills/' class='text-brand-red hover:underline'>DVSA 27 driving skills framework</a> with 8 categories and 27 skills. It tracks each student's proficiency on a 6-level scale (Not Started to Reflection). This isn't a direct DVSA API integration, but a comprehensive curriculum tracking system that ensures cross-instructor continuity—any instructor can pick up exactly where the last left off.",
    links: [
      { text: 'See the 27 driving skills', url: '/dvsa-27-driving-skills/' },
      { text: 'Student progress tracking', url: '/driving-school-management-software/' }
    ]
  },
  {
    question: "Can I track student progress?",
    answer: "Yes. The full DVSA competency framework tracks 27 skills across 8 categories with a 6-level proficiency scale. After each lesson, instructors record which competencies were covered and update proficiency levels. Students see their progress through their portal, which motivates them and reduces 'When will I be ready?' questions.",
    links: [
      { text: 'Progress tracking features', url: '/driving-school-management-software/' }
    ]
  },
  {
    question: "How does automated billing work?",
    answer: "Create lesson packages with configurable hours, pricing, and expiry dates. The system generates invoices with line items, tracks payment status through a full lifecycle, and sends invoices to students via email. Record payments via cash, bank transfer, or cheque. Online card payments via Stripe are coming soon.",
    links: [
      { text: 'See pricing', url: '/pricing/' }
    ]
  },
  {
    question: "Is driving school software suitable for solo ADIs?",
    answer: "Yes. Many of our users are independent ADIs who need better organisation without the complexity of enterprise software. The Solo Plan (£29/month) includes unlimited students, DVSA progress tracking, automated reminders, and invoicing—everything a solo instructor needs to run professionally.",
    links: [
      { text: 'Solo plan details', url: '/pricing/' },
      { text: 'Join early access', url: '/early-access/' }
    ]
  },
  {
    question: "Can I manage multiple instructors?",
    answer: "Yes. The School Plan (£79/month) supports up to 5 instructors with individual calendars, student assignments, vehicle allocation, and performance tracking. Each instructor gets their own login with role-based access. Enterprise plans support unlimited instructors with dedicated support and custom onboarding.",
    links: [
      { text: 'School plan details', url: '/pricing/' },
      { text: 'Management features', url: '/driving-school-management-software/' }
    ]
  },
  {
    question: "Does driving school software send lesson reminders?",
    answer: "Yes. Automated reminders go out via email (Resend) with configurable timing (SMS coming soon). You can set per-student notification preferences, and full delivery logs let you verify every message was sent and received. This reduces no-shows significantly.",
    links: [
      { text: 'Scheduling features', url: '/driving-school-scheduling-software/' }
    ]
  },
  {
    question: "What about vehicle tracking?",
    answer: "DriveSchoolPro includes vehicle compliance tracking for MOT dates, tax, and insurance expiry with automated alerts. This ensures your vehicles stay roadworthy and legally compliant. Vehicle fleet management is included in the School Plan and above.",
    links: [
      { text: 'School plan details', url: '/pricing/' }
    ]
  }
];
---

<BaseLayout title="Driving School Software for UK ADIs | DVSA Tracking & Scheduling | DriveSchoolPro" description="Driving school software built for UK ADIs. Full DVSA 27-skills tracking, three-way scheduling with conflict detection, automated reminders, and pupil portal. From £29/month." image="/images/marketing/calendar-week-view.webp">
  <!-- Breadcrumbs with Schema -->
  <BreadcrumbsEnhanced
    site="driveschool"
    items={[
      { label: 'Home', href: '/' },
      { label: 'Driving School Software', href: '/driving-school-software/' }
    ]}
  />

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-software.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <span class="badge-primary mb-4">Driving School Software</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Driving School Software That Works As Hard As You Do</h1>
        <p class="text-xl text-gray-300 mb-8">
          Stop juggling spreadsheets, WhatsApp messages, and paper diaries. DriveSchoolPro brings everything together in one powerful platform.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/early-access/" class="btn-primary text-lg px-8 py-4">Become a Founding Member</a>
          <a href="/pricing/" class="btn-secondary text-lg px-8 py-4">See Driving School Software Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Answer -->
  <FeaturedAnswer question="What is driving school software?">
    Driving school software is a management platform for ADIs and driving schools that handles lesson scheduling, student progress tracking, test date management, invoicing, and instructor allocation. Modern platforms like DriveSchoolPro include a full DVSA competency framework with 27 skills across 8 categories, three-way conflict detection for scheduling, and automated email reminders that save instructors 10+ hours weekly.
  </FeaturedAnswer>

  <!-- Statistics Section -->
  <StatisticsSection
    site="driveschool"
    pageUrl="https://driveschoolpro.com/driving-school-software/"
    title="UK Driving School Industry Overview"
    stats={drivingStats}
  />

  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Why Driving Schools Need Proper Software</h2>
        <p class="text-lg text-gray-600 mb-6">
          You became a driving instructor to teach people to drive, not to spend evenings managing spreadsheets. But without the right tools, admin eats into your teaching time—and your income.
        </p>
        <p class="text-gray-600 mb-8">
          DriveSchoolPro handles the business side so you can focus on what you do best: helping students pass their tests.
        </p>

        <h2 class="text-3xl font-bold text-brand-navy mb-8">Core Features</h2>
      </div>

      <!-- Full-width dashboard screenshot -->
      <div class="max-w-5xl mx-auto mb-12">
        <MarketingScreenshot
          src="/images/marketing/dashboard-overview.webp"
          width={1440}
          height={900}
          alt="DriveSchoolPro dashboard showing business metrics, today's lessons, compliance alerts, and quick action buttons"
        />
      </div>

      <div class="max-w-5xl mx-auto">
        <!-- Three-Way Scheduling -->
        <div class="grid md:grid-cols-2 gap-10 items-center mb-16">
          <div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Three-Way Scheduling</h3>
            <p class="text-gray-700">Drag-and-drop calendar with conflict detection across students, instructors, and vehicles. Day, week, and month views with recurring lesson series.</p>
          </div>
          <MarketingScreenshot
            src="/images/marketing/calendar-week-view.webp"
            width={1440}
            height={900}
            alt="Interactive weekly calendar with colour-coded lessons across multiple instructors and drag-and-drop scheduling"
          />
        </div>

        <!-- DVSA Progress Tracking -->
        <div class="grid md:grid-cols-2 gap-10 items-center mb-16">
          <div class="order-2 md:order-1">
            <MarketingScreenshot
              src="/images/marketing/dvsa-progress-tracking.webp"
              width={1440}
              height={900}
              alt="DVSA competency tracking grid showing 8 skill categories with proficiency levels from Not Started to Reflection"
            />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="text-xl font-bold text-brand-navy mb-3">DVSA Progress Tracking</h3>
            <p class="text-gray-700">Full DVSA competency framework — 8 categories, 27 skills with 6-level proficiency scale. Cross-instructor continuity so any instructor sees the full picture.</p>
          </div>
        </div>

        <!-- Student Portal -->
        <div class="grid md:grid-cols-2 gap-10 items-center mb-16">
          <div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Student Portal</h3>
            <p class="text-gray-700">Secure student login to view lessons, track DVSA progress, check package balances, and manage personal details.</p>
          </div>
          <div class="flex justify-center">
            <MarketingScreenshot
              src="/images/marketing/portal-dashboard-mobile.webp"
              width={375}
              height={1193}
              alt="Student self-service portal on mobile showing upcoming lesson, progress summary, and active packages"
              mobile
            />
          </div>
        </div>

        <!-- Invoicing & Packages -->
        <div class="grid md:grid-cols-2 gap-10 items-center mb-8">
          <div class="order-2 md:order-1">
            <MarketingScreenshot
              src="/images/marketing/payments.webp"
              width={1440}
              height={900}
              alt="Professional invoice with itemised charges, VAT breakdown, and email delivery status"
            />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="text-xl font-bold text-brand-navy mb-3">Invoicing & Packages</h3>
            <p class="text-gray-700">Invoices with line items, payment recording (cash, bank transfer, cheque), and email delivery. Lesson packages with automatic hour tracking.</p>
          </div>
        </div>
      </div>

      <div class="max-w-4xl mx-auto">

      </div>
    </div>
  </section>

  <!-- Calculator Callout -->
  <section class="section bg-brand-red-light">
    <div class="container-custom">
      <div class="bg-white rounded-xl shadow-md p-8 md:p-12">
        <div class="flex items-start gap-6">
          <div class="flex-shrink-0">
            <svg class="w-16 h-16 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-brand-navy mb-3">
              Plan Your Driving School Finances
            </h3>
            <p class="text-gray-600 mb-4">
              Before investing in software, understand your potential earnings and costs. Our free calculator
              shows your effective hourly rate, break-even utilization, and profit projections with UK industry benchmarks.
            </p>
            <a href="/driving-school-calculator/" class="btn-primary inline-flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
              Calculate Your Revenue & Earnings
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <ComparisonTable
    title="Why Driving Schools Choose DriveSchoolPro"
    headers={['DriveSchoolPro', 'Generic Software', 'Manual/Spreadsheets']}
    rows={comparisonData}
  />

  <!-- FAQ Section -->
  <FAQEnhanced
    site="driveschool"
    pageUrl="https://driveschoolpro.com/driving-school-software/"
    title="Frequently Asked Questions About Driving School Software"
    faqs={faqItems}
  />

  <!-- Further Reading -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Further Reading</h2>
        <p class="text-gray-600 mb-8">Explore our in-depth guides to help you get the most from driving school software.</p>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/blog/best-driving-school-software/" class="card p-6 hover:border-brand-red border border-transparent transition-colors group">
            <h3 class="font-bold text-brand-navy group-hover:text-brand-red mb-2 transition-colors">Best Driving School Software</h3>
            <p class="text-sm text-gray-600">A head-to-head comparison of the top platforms for UK ADIs and driving schools.</p>
            <span class="inline-flex items-center gap-1 text-brand-red text-sm font-semibold mt-3">
              Read guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
          <a href="/blog/how-to-choose-driving-school-scheduling-software/" class="card p-6 hover:border-brand-red border border-transparent transition-colors group">
            <h3 class="font-bold text-brand-navy group-hover:text-brand-red mb-2 transition-colors">How to Choose Scheduling Software</h3>
            <p class="text-sm text-gray-600">What to look for when selecting scheduling software for your driving school.</p>
            <span class="inline-flex items-center gap-1 text-brand-red text-sm font-semibold mt-3">
              Read guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
          <a href="/blog/reduce-no-shows-driving-school/" class="card p-6 hover:border-brand-red border border-transparent transition-colors group">
            <h3 class="font-bold text-brand-navy group-hover:text-brand-red mb-2 transition-colors">Reduce No-Shows at Your Driving School</h3>
            <p class="text-sm text-gray-600">Practical strategies to cut cancellations and late arrivals using automated reminders.</p>
            <span class="inline-flex items-center gap-1 text-brand-red text-sm font-semibold mt-3">
              Read guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
          <a href="/blog/student-progress-tracking/" class="card p-6 hover:border-brand-red border border-transparent transition-colors group">
            <h3 class="font-bold text-brand-navy group-hover:text-brand-red mb-2 transition-colors">Student Progress Tracking</h3>
            <p class="text-sm text-gray-600">How digital DVSA competency tracking improves pass rates and student motivation.</p>
            <span class="inline-flex items-center gap-1 text-brand-red text-sm font-semibold mt-3">
              Read guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-gradient-to-r from-brand-red to-brand-red-dark text-white">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Simplify Your Driving School?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Join our founding members and streamline your driving school.
      </p>
      <a href="/early-access/" class="btn bg-white text-brand-red hover:bg-gray-100 text-lg px-8 py-4">Become a Founding Member</a>
    </div>
  </section>
</BaseLayout>
