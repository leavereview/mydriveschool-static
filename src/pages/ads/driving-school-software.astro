---
import { OFFER } from '../../config/offer';
import LandingLayout from '../../layouts/LandingLayout.astro';

const GOOGLE_ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID || '';
const GOOGLE_ADS_CONVERSION_LABEL = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_LABEL || '';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does the AI actually do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DriveSchoolPro uses Anthropic's Claude model to generate a 3–4 sentence briefing for each lesson based on your previous notes and the pupil's progress. It's not a chatbot — it's lesson prep that's already written for you when you open the card. You can turn it off if you don't want it, and your pupil data is never used to train AI models."
      }
    },
    {
      "@type": "Question",
      "name": "Is this different from Total Drive or other apps?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most UK driving school apps are digital diaries. DriveSchoolPro is a full platform: AI lesson briefings, the complete DVSA 8-category framework (not just a progress bar), automated Google review generation, and Stripe Connect payments — all included. See a detailed comparison at driveschoolpro.com/compare/total-drive."
      }
    },
    {
      "@type": "Question",
      "name": "Is DriveSchoolPro free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${OFFER.long} with full access to all features — no credit card required. After that, it's £29/month with no contracts.`
      }
    },
    {
      "@type": "Question",
      "name": "Does DriveSchoolPro work on my phone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. DriveSchoolPro is fully responsive and works on any device — iPhone, Android, iPad, laptop, or desktop. Most ADIs use it on their phone between lessons."
      }
    },
    {
      "@type": "Question",
      "name": "Does it track DVSA driving skills?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We track all 27 DVSA driving skills across 8 categories using the official Ready to Pass framework. Students can view their own progress through a self-service portal."
      }
    },
    {
      "@type": "Question",
      "name": "Can I switch from my paper diary easily?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most ADIs are fully set up within 10 minutes. Add your students and schedule your first lesson — you can run both systems in parallel until you're comfortable."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. All plans are month-to-month. Cancel anytime with no fees."
      }
    }
  ]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "DriveSchoolPro",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web, iOS, Android",
  "url": "https://driveschoolpro.com",
  "offers": {
    "@type": "Offer",
    "price": "29",
    "priceCurrency": "GBP",
    "priceValidUntil": "2026-12-31",
    "description": "Solo plan — unlimited students, DVSA tracking, automated reminders"
  },
  "description": "Driving school management software for UK ADIs. Smart scheduling, DVSA progress tracking, and automated reminders.",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "4"
  }
};

const features = [
  { name: 'AI lesson briefings', desc: 'Pre-generated for every lesson — saves 5–10 minutes' },
  { name: 'Full DVSA framework', desc: '8 categories, 27 skills, test readiness scoring' },
  { name: 'Automated Google review requests', desc: 'Triggered automatically on every test pass' },
  { name: 'WhatsApp + SMS reminders', desc: 'Automated before every lesson, reduces no-shows' },
  { name: 'Three-way scheduling', desc: 'Pupil, instructor, and vehicle conflicts auto-detected' },
  { name: 'Embeddable booking widget', desc: 'Pupils book directly on your own website' },
  { name: 'Stripe Connect payments', desc: 'Take card payments, send invoices, track balances' },
  { name: 'Works on any device', desc: 'Phone, tablet, laptop — fully responsive' }
];
---

<LandingLayout
  title="Driving School Software for UK ADIs — 3 Months Free | DriveSchoolPro"
  description="Purpose-built driving school software with DVSA progress tracking, smart scheduling, and automated reminders. Start your free trial — no credit card required."
  ogImage="/images/marketing/dashboard-overview.webp"
>
  <meta name="robots" content="noindex, follow" slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} slot="head" />

  <!-- Conversion tracking setup -->
  <script is:inline define:vars={{ GOOGLE_ADS_ID, GOOGLE_ADS_CONVERSION_LABEL }} slot="head">
    window.trackAdConversion = function(url) {
      if (typeof window.gtag === 'function' && GOOGLE_ADS_ID && GOOGLE_ADS_CONVERSION_LABEL) {
        window.gtag('event', 'conversion', {
          'send_to': GOOGLE_ADS_ID + '/' + GOOGLE_ADS_CONVERSION_LABEL,
          'event_callback': function() { window.location = url; }
        });
        setTimeout(function() { window.location = url; }, 1000);
        return false;
      }
      window.location = url;
    };
  </script>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="bg-white pt-10 pb-12 md:pt-16 md:pb-20">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-center md:gap-12 lg:gap-16">

        <!-- Text -->
        <div class="md:w-1/2 mb-10 md:mb-0">
          <div class="flex items-center gap-2 mb-8">
            <span class="text-2xl font-bold text-brand-navy tracking-tight">DriveSchool<span class="text-brand-red">Pro</span></span>
          </div>

          <!-- Launch offer badge -->
          <div class="inline-flex items-center gap-2 bg-brand-red-light text-brand-red text-sm font-semibold px-3 py-1.5 rounded-full mb-5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Launch Offer: 50% off your first 3 months
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-brand-navy leading-tight mb-4">
            The <span class="text-brand-red">driving school platform</span> that does the thinking for you
          </h1>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            AI-generated lesson briefings. DVSA competency tracking across the full 8-category framework. Automated Google review requests that grow your school. Everything a UK driving instructor needs — in one place.
          </p>

          <a
            href={OFFER.ctaPrimary.href}
            onclick="return trackAdConversion(this.href)"
            class="inline-block w-full md:w-auto text-center bg-brand-red text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-red-700 transition-colors"
          >
            {OFFER.ctaPrimary.label} &rarr;
          </a>
          <p class="text-sm text-gray-400 mt-3">No credit card required &middot; {OFFER.short} &middot; Cancel anytime</p>
        </div>

        <!-- Hero image -->
        <div class="md:w-1/2">
          <link rel="preload" as="image" href="/images/marketing/dashboard-overview.webp" />
          <img
            src="/images/marketing/dashboard-overview.webp"
            alt="DriveSchoolPro dashboard showing lesson schedule, student progress, and reminders"
            class="rounded-2xl shadow-xl border border-gray-100 w-full"
            width="720"
            height="480"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ── Social Proof Bar ──────────────────────────────────────────── -->
  <section class="bg-gray-50 py-6 border-y border-gray-100">
    <div class="container-custom">
      <div class="flex flex-wrap justify-center gap-6 md:gap-10 text-sm font-medium text-gray-600">
        <span class="flex items-center gap-2">
          <span class="text-base">🇬🇧</span> Built for UK ADIs
        </span>
        <span class="hidden md:block text-gray-200">|</span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          27 DVSA Skills Tracked
        </span>
        <span class="hidden md:block text-gray-200">|</span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          10+ Hours Saved Weekly
        </span>
        <span class="hidden md:block text-gray-200">|</span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Trusted by ADIs Across the UK
        </span>
      </div>
    </div>
  </section>

  <!-- ── Feature Cards ─────────────────────────────────────────────── -->
  <section class="section bg-white">
    <div class="container-custom">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-navy text-center mb-3">
        AI, DVSA Tracking, and Automated Reviews — in One Platform
      </h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Built around the three things that make a driving school grow: better lessons, clearer progress, and more Google reviews.</p>
      <div class="grid md:grid-cols-3 gap-6">

        <!-- Card 1: AI Lesson Briefings -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">AI Lesson Briefings</p>
          <p class="text-gray-600 text-sm leading-relaxed">Every lesson comes with a pre-generated briefing — what you covered last time, what to focus on today. Saves 5–10 minutes per lesson.</p>
        </div>

        <!-- Card 2: DVSA Framework Tracking -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">DVSA Framework Tracking</p>
          <p class="text-gray-600 text-sm leading-relaxed">Not a generic progress bar. All 8 official DVSA categories and 27 skills, tracked lesson by lesson. Test readiness scoring built in.</p>
        </div>

        <!-- Card 3: Automated Google Reviews -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">Automated Google Reviews</p>
          <p class="text-gray-600 text-sm leading-relaxed">Every pupil who passes is automatically asked for a Google review. The single fastest way to grow a UK driving school.</p>
        </div>

        <!-- Card 4: WhatsApp + SMS Reminders -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">WhatsApp + SMS Reminders</p>
          <p class="text-gray-600 text-sm leading-relaxed">UK pupils actually read WhatsApp. Automated reminders reduce no-shows by 30–50%. SMS included as backup.</p>
        </div>

        <!-- Card 5: Three-Way Scheduling -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">Three-Way Scheduling</p>
          <p class="text-gray-600 text-sm leading-relaxed">Pupil, instructor, and vehicle conflicts all detected automatically. Drag-and-drop calendar. Mobile-first so you can manage between lessons.</p>
        </div>

        <!-- Card 6: Embeddable Booking Widget -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 mb-2">Embeddable Booking Widget</p>
          <p class="text-gray-600 text-sm leading-relaxed">Drop our booking form into your existing website. Pupils book directly without leaving your site. Your brand, our engine.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── How It Works ────────────────────────────────────────────────── -->
  <section class="section bg-gray-50 border-t border-gray-100">
    <div class="container-custom">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-navy text-center mb-10">Up and Running in Minutes</h2>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-brand-red text-white font-bold text-xl flex items-center justify-center mx-auto mb-4">1</div>
          <h3 class="font-semibold text-gray-900 mb-2">Sign up in 3 minutes</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Set up your school, import pupils, connect Stripe. No training required.</p>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-brand-red text-white font-bold text-xl flex items-center justify-center mx-auto mb-4">2</div>
          <h3 class="font-semibold text-gray-900 mb-2">Teach with AI at your side</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Open each lesson, get an AI briefing. Mark progress against DVSA skills as you go.</p>
        </div>

        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-brand-red text-white font-bold text-xl flex items-center justify-center mx-auto mb-4">3</div>
          <h3 class="font-semibold text-gray-900 mb-2">Watch reviews roll in</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Every test pass triggers an automated Google review request. Your reputation grows on autopilot.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Testimonials ──────────────────────────────────────────────── -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="text-center mb-10">
        <span class="text-brand-red font-semibold text-sm uppercase tracking-wider">From Real Driving Instructors</span>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-navy mt-2">Trusted by UK Driving Instructors</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex gap-1 mb-4" aria-label="5 out of 5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-gray-700 text-sm leading-relaxed mb-5">
            "Set up in ten minutes. Genuinely easier than my paper diary."
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-red-light flex items-center justify-center flex-shrink-0">
              <span class="text-brand-red font-semibold text-xs">SJ</span>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">Sarah J.</div>
              <div class="text-gray-400 text-xs">Independent ADI · Birmingham</div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex gap-1 mb-4" aria-label="5 out of 5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-gray-700 text-sm leading-relaxed mb-5">
            "One no-show in the last month. Used to be two or three a week."
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-red-light flex items-center justify-center flex-shrink-0">
              <span class="text-brand-red font-semibold text-xs">RK</span>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">Rachel K.</div>
              <div class="text-gray-400 text-xs">Independent ADI · Manchester</div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex gap-1 mb-4" aria-label="5 out of 5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-gray-700 text-sm leading-relaxed mb-5">
            "If you can use WhatsApp, you can use this. I picked it up straightaway."
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-red-light flex items-center justify-center flex-shrink-0">
              <span class="text-brand-red font-semibold text-xs">DP</span>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">David P.</div>
              <div class="text-gray-400 text-xs">ADI, 8 years experience · Bristol</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Feature Checklist ─────────────────────────────────────────── -->
  <section class="section bg-white">
    <div class="container-custom">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-navy text-center mb-10">Everything Included — No Per-Feature Upsells</h2>
      <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-3">
        {features.map((f) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
