---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Get Started — DriveSchoolPro"
  description="Create your DriveSchoolPro account and start your free trial."
  noindex={true}
>
  <section class="min-h-screen flex items-center justify-center bg-brand-navy text-white">
    <div class="text-center px-4">
      <h1 class="text-3xl font-bold mb-4">DriveSchoolPro is now live!</h1>
      <p class="text-gray-300 mb-8">You're being redirected to sign up...</p>
      <a href="https://app.driveschoolpro.com/signup" class="btn-primary text-lg px-8 py-4">
        Create Your Account
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  window.location.replace('https://app.driveschoolpro.com/signup');
</script>
